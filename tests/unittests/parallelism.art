; Parallelism / concurrency unit tests.
;
; Covers the surface added on `add-new-Task-value`:
;   :task value, do.async (in-process fiber + .isolated subprocess),
;   wait / wait.all / wait.first[.cancel] / wait.timeout,
;   cancel / finished? / failed?,
;   error propagation as :error,
;   :event + on / emit / off / on.once + task callbacks,
;   fan-out iterators: map.async, loop.async, map.parallel,
;   every?.parallel, some?.parallel, select.parallel.

topic: $[topic :string] -> print ~"\n>> |topic|"
passed: $[] -> print "[+] passed!"
; small in-process task that flushes the fiber scheduler between iterator
; topics. plain `pause` from main isn't enough; an explicit task is.
drain: $[] -> wait do.async [pause 20]


topic ":task value"
do [

    t: do.async [40 + 2]
    ensure -> :task = type t
    passed

    ensure -> 42 = wait t
    passed

    ensure -> finished? t
    ensure -> not? failed? t
    passed

]


topic "do.async — in-process closure capture"
do [

    x: 10
    ensure -> 42 = wait do.async [x + 32]
    passed

    y: [1 2 3]
    ensure -> 6 = wait do.async [sum y]
    passed

]


topic "do.async — :error fidelity"
do [

    e: wait do.async [1 / 0]
    ensure -> :error = type e
    passed

    ensure -> :errorKind = type e\kind
    ensure -> string? e\message
    passed

]


topic "wait.all — order preserved"
do [

    ts: map 1..5 'i [do.async [i * 10]]
    ensure -> [10 20 30 40 50] = wait.all ts
    passed

]


topic "wait.all — failures slot in as :error"
do [

    ts: @[do.async [10] do.async [1 / 0] do.async [30]]
    rs: wait.all ts
    ensure -> 3 = size rs
    ensure -> 10 = rs\0
    ensure -> :error = type rs\1
    ensure -> 30 = rs\2
    passed

]


topic "wait.first[.cancel]"
do [

    t1: do.async [pause 500 'late]
    t2: do.async [pause 50 'early]
    ensure -> 'early = wait.first.cancel @[t1 t2]
    passed

]


topic "wait.timeout — bare wait with budget"
do [

    t: do.async [pause 1000]
    r: wait.timeout: 50 t
    ensure -> :error = type r
    cancel t
    passed

    fast: do.async [40 + 2]
    ensure -> 42 = wait.timeout: 5000 fast
    passed

]


topic "cancel"
do [

    t: do.async [pause 5000]
    cancel t
    ensure -> null = wait t
    ensure -> not? failed? t
    passed

]


topic "pause from main pumps the fiber scheduler"
do [

    t: do.async [pause 200 99]
    pause 400
    ensure -> finished? t
    ensure -> 99 = wait t
    passed

]


topic "do.async.isolated — subprocess flavor"
do [

    ensure -> 7 = wait do.async.isolated [3 + 4]
    passed

    ensure -> 15 = wait do.async.isolated [sum 1..5]
    passed

]


topic "map.async — fan-out parallel map"
do [

    ensure -> [1 4 9 16 25] = map.async 1..5 'x [x * x]
    drain
    passed

]


topic "map.parallel — order preserved"
do [

    ensure -> [1 4 9 16 25] = map.parallel 1..5 'x [x * x]
    drain
    passed

]


topic "loop.async — fan-out side-effect loop"
do [

    acc: []
    loop.async 1..4 'x [ 'acc ++ x * x ]
    drain
    ensure -> [1 4 9 16] = sort acc
    passed

]


topic "select.parallel — order preserved"
do [

    ensure -> [2 4 6 8 10] = select.parallel 1..10 'n -> even? n
    drain
    passed

]


topic "every?.parallel"
do [

    ensure -> every?.parallel [2 4 6 8] 'n -> even? n
    ensure -> not? every?.parallel [2 4 5 8] 'n -> even? n
    drain
    passed

]


topic "some?.parallel"
do [

    ensure -> some?.parallel [1 3 6 7] 'n -> even? n
    ensure -> not? some?.parallel [1 3 5 7] 'n -> even? n
    drain
    passed

]


topic ":event value"
do [

    E: event 'sample
    ensure -> :event = type E
    passed

]


topic "on / emit — payload via .with:"
do [

    E: event 'payload
    got: []
    on.with:'p E [ 'got ++ p ]
    emit.with: "a" E
    emit.with: "b" E
    drain
    ensure -> ["a" "b"] = got
    passed

]


topic "off — bulk unsubscribe"
do [

    E: event 'silenced
    n: 0
    on.with:'p E [ inc 'n ]
    emit.with: 1 E
    drain
    off E
    emit.with: 2 E
    drain
    ensure -> 1 = n
    passed

]


topic "on.once — fires only once"
do [

    E: event 'oneshot
    n: 0
    on.once.with:'p E [ inc 'n ]
    emit.with: 1 E
    emit.with: 2 E
    emit.with: 3 E
    drain
    ensure -> 1 = n
    passed

]


topic "on .id + off id — per-handler unsubscribe"
do [

    E: event 'targeted
    a: 0, b: 0
    idA: on.id.with:'p E [ inc 'a ]
    on.with:'p E [ inc 'b ]
    emit.with: 1 E
    drain
    off idA
    emit.with: 2 E
    drain
    ensure -> 1 = a
    ensure -> 2 = b
    passed

]


topic "task callbacks — on.done"
do [

    t: do.async [pause 50 99]
    seen: []
    on.done.with:'r t [ 'seen ++ r ]
    wait t
    drain
    ensure -> [99] = seen
    passed

]


topic "task callbacks — on.failed"
do [

    t: do.async [1 / 0]
    failures: []
    on.failed.with:'e t [ 'failures ++ type e ]
    wait t
    drain
    ensure -> [:error] = failures
    passed

]
