import {unitt}!

describe "Allowed Operations" [

    it "arrange with empty block" [
        expects -> equal? [] arrange [] 'x -> x
    ]

    it "arrange with single element" [
        expects -> equal? [42] arrange [42] 'x -> x
    ]

    it "arrange ascending by identity" [
        expects -> equal? [1 1 2 3 4 5 6 9] arrange [3 1 4 1 5 9 2 6] 'x -> x
    ]

    it "arrange descending by identity" [
        expects -> equal? [5 4 3 2 1] arrange.descending [1 2 3 4 5] 'x -> x
    ]

    it "arrange by size" [
        expects -> equal? ["the" "fox" "the" "dog" "over" "lazy" "brown" "jumped"]
                          arrange ["the" "brown" "fox" "jumped" "over" "the" "lazy" "dog"] => size
    ]

    it "arrange.descending by size" [
        expects -> equal? ["jumped" "brown" "over" "lazy" "the" "fox" "the" "dog"]
                          arrange.descending ["the" "brown" "fox" "jumped" "over" "the" "lazy" "dog"] => size
    ]

    it "arrange.with using index keeps order on stable input" [
        expects -> equal? [10 20 30] arrange.with:'i [10 20 30] [x] -> i
    ]

    it "arrange over a range" [
        expects -> equal? [1 2 3 4 5] arrange 1..5 'x -> x
    ]

]