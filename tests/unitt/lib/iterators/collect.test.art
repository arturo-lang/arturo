import {unitt}!

describe "Allowed Operations" [

    it "collect with empty block" [
        expects -> equal? [] collect [] => odd?
    ]

    it "collect takes prefix while predicate holds" [
        expects -> equal? [1 3 5] collect [1 3 5 4 6 7] => odd?
    ]

    it "collect over a range" [
        expects -> equal? [1 2] collect 1..5 'x -> x < 3
    ]

    it "collect when nothing matches yields empty block" [
        expects -> equal? [] collect [2 4 6] => odd?
    ]

    it "collect when everything matches yields whole input" [
        expects -> equal? [1 3 5] collect [1 3 5] => odd?
    ]

    it "collect.after returns suffix from first matching element" [
        expects -> equal? [3 5 2 0 1] collect.after [4 6 3 5 2 0 1] => odd?
    ]

    it "collect.after over a range" [
        expects -> equal? [4 5 6] collect.after 1..6 'x -> x > 3
    ]

    it "collect.after with no match returns empty block" [
        expects -> equal? [] collect.after [2 4 6] => odd?
    ]

    it "collect.after with empty input returns empty block" [
        expects -> equal? [] collect.after [] => odd?
    ]

]
