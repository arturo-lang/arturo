tests: select list "src/helpers" => [suffix? & ".nim"]
'tests -- [
    "src/helpers/js.nim"
]

success: true
loop tests 'test [
    unless zero? execute.directly.code join split.lines ~{
        nim 
        --skipParentCfg 
        --verbosity:0 
        --warning:all:off 
        --hint:all:off 
        --path:src 
        r 
        |test|
    } -> success: false
]

unless success ->
    panic.unstyled "Tests failed"